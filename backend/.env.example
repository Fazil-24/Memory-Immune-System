# LLM used by Cognee's own pipelines (cognify/remember/recall/improve) and by
# our own conflict-judge + answer-synthesis calls. Cerebras hosts gpt-oss-120b
# via an OpenAI-compatible API (litellm model id: cerebras/gpt-oss-120b).
# Cognee's own LLMProvider enum has no "cerebras" branch, so route through its
# generic "custom" provider (which just hands the model string to litellm,
# and litellm resolves the cerebras/ prefix natively).
LLM_PROVIDER=custom
LLM_MODEL=cerebras/gpt-oss-120b
LLM_API_KEY=csk-...

# Cerebras doesn't serve embeddings, so we use fastembed (local, no API key,
# runs a small ONNX model on CPU) instead of OpenAI's embedding API.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Disable multi-tenant/backend auth for the demo (single local user).
ENABLE_BACKEND_ACCESS_CONTROL=false

DATASET_NAME=compliance_brain
